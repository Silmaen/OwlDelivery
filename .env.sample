# Environment variables for the Django application
DEBUG_MODE=False
TZ=Europe/Paris
PUID=1000
PGID=1000
PORT=8080
PATH_DATA=./docker_data/data
DOMAIN_NAME=example.com
# Admin user credentials
ADMIN_NAME=admin
ADMIN_PASSWD=admin
# SMTP configuration
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Optional: Enable staff user creation (default: False)
ENABLE_STAFF=False
